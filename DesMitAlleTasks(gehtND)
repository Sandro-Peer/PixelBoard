// FIX 7 & 8: connectWiFi gibt bool zurück, kein hängender Aufruf
bool connectWiFi() {
  Serial.println("[WiFi] Verbinde...");
  WiFi.begin(ssid, password);
  int tries = 0;
  while (WiFi.status() != WL_CONNECTED && tries < 20) {
    vTaskDelay(pdMS_TO_TICKS(500));
    Serial.print(".");
    tries++;
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n[WiFi] Verbunden!");
    return true;
  }
  Serial.println("\n[WiFi] Verbindung fehlgeschlagen!");
  return false;
}

String conditionToLabel(int code) {
  if (code >= 200 && code < 300) return "gewitter";
  if (code >= 300 && code < 400) return "niesel";
  if (code >= 500 && code < 600) return "regen";
  if (code >= 600 && code < 700) return "schnee";
  if (code >= 700 && code < 800) return "nebel";
  if (code == 800)               return "sonnig";
  if (code == 801)               return "leicht";
  if (code == 802)               return "wolkig";
  if (code >= 803)               return "bedeckt";
  return "unbekannt";
}

void fetchWeather() {
  if (WiFi.status() != WL_CONNECTED) {
    if (!connectWiFi()) return;
  }

  HTTPClient http;
  String url = "http://api.openweathermap.org/data/2.5/weather?q=" + String(city)
             + "&appid=" + String(apiKey) + "&units=metric&lang=de";
  http.begin(url);
  int httpCode = http.GET();

  if (httpCode == HTTP_CODE_OK) {
    String payload = http.getString();
    DynamicJsonDocument doc(2048);
    DeserializationError error = deserializeJson(doc, payload);

    if (!error) {
      WeatherData wd;
      wd.temp      = doc["main"]["temp"].as<float>();
      wd.condition = doc["weather"][0]["id"].as<int>();
      wd.label     = conditionToLabel(wd.condition);

      if (xSemaphoreTake(xWeatherMutex, pdMS_TO_TICKS(1000)) == pdTRUE) {
        gWeather       = wd;
        gParticlesInit = false;
        xSemaphoreGive(xWeatherMutex);
      }
      Serial.printf("[Weather] %.1f°C, %s\n", wd.temp, wd.label.c_str());
    } else {
      Serial.printf("[Weather] JSON Fehler: %s\n", error.c_str());
    }
  } else {
    Serial.printf("[Weather] HTTP Fehler: %d\n", httpCode);
  }
  http.end();
}

