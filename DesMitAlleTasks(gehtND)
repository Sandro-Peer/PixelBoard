#define MAX_SNAKE_LENGTH 150
struct Point { int x; int y; };

static Point   snakeBody[MAX_SNAKE_LENGTH];
static int     snakeLength;
static int     snakeDirX,     snakeDirY;
static int     snakeLastDirX, snakeLastDirY;
static Point   snakeFood;
static int     snakeSpeed;
static uint8_t snakeHue;

static const int SNAKE_BASE_SPEED = 200;
static const int SNAKE_MIN_SPEED  = 80;

void snakeSpawnFood() {
  bool valid = false;
  while (!valid) {
    snakeFood.x = random(0, MATRIX_WIDTH);
    snakeFood.y = random(0, MATRIX_HEIGHT);
    valid = true;
    for (int i = 0; i < snakeLength; i++)
      if (snakeBody[i].x == snakeFood.x && snakeBody[i].y == snakeFood.y) { valid = false; break; }
  }
}

void snakeReset() {
  snakeLength   = 3;
  snakeBody[0]  = {16, 8}; snakeBody[1] = {15, 8}; snakeBody[2] = {14, 8};
  snakeDirX     = 1;  snakeDirY     = 0;
  snakeLastDirX = 1;  snakeLastDirY = 0;
  snakeSpeed    = SNAKE_BASE_SPEED;
  snakeHue      = 0;
  snakeSpawnFood();
}

bool snakeCheckCollision(int x, int y) {
  if (x < 0 || x >= MATRIX_WIDTH || y < 0 || y >= MATRIX_HEIGHT) return true;
  for (int i = 1; i < snakeLength; i++)
    if (snakeBody[i].x == x && snakeBody[i].y == y) return true;
  return false;
}

void snakeReadJoystick() {
  int dx = analogRead(JOY_X_PIN) - JOY_CENTER;
  int dy = analogRead(JOY_Y_PIN) - JOY_CENTER;
  if (abs(dx) < JOY_DEADZONE && abs(dy) < JOY_DEADZONE) return;
  if (abs(dx) > abs(dy)) {
    if (dx < -JOY_THRESHOLD && snakeLastDirX !=  1) { snakeDirX = -1; snakeDirY =  0; }
    else if (dx >  JOY_THRESHOLD && snakeLastDirX != -1) { snakeDirX =  1; snakeDirY =  0; }
  } else {
    if (dy < -JOY_THRESHOLD && snakeLastDirY != -1) { snakeDirX =  0; snakeDirY =  1; }
    else if (dy >  JOY_THRESHOLD && snakeLastDirY !=  1) { snakeDirX =  0; snakeDirY = -1; }
  }
}

void snakeDraw() {
  clearLeds();
  for (int i = 0; i < snakeLength; i++) {
    uint8_t hue = snakeHue + (i * 255 / snakeLength);
    if (i == 0)
      setPixelXY(snakeBody[i].x, snakeBody[i].y, CHSV(hue, 200, 255));
    else {
      uint8_t brightness = 255 - (i * 100 / snakeLength);
      setPixelXY(snakeBody[i].x, snakeBody[i].y, CHSV(hue, 255, brightness));
    }
  }
  setPixelXY(snakeFood.x, snakeFood.y, CHSV(0, 255, beatsin8(60, 100, 255)));
}

// =====================================================
// TASK: INPUT
// =====================================================
void vTaskInput(void* pvParameters) {
  pinMode(JOY_BTN_PIN, INPUT_PULLUP);
  bool lastBtn = HIGH; bool joyMoved = false; TickType_t lastRepeat = 0;

  for (;;) {
    int  rawX   = analogRead(JOY_X_PIN);
    int  rawY   = analogRead(JOY_Y_PIN);
    bool btnNow = digitalRead(JOY_BTN_PIN);
    int  dx     = rawX - JOY_CENTER;
    int  dy     = rawY - JOY_CENTER;

    JoyEvent_t ev = JOY_NONE;
    if (abs(dx) > abs(dy)) {
      if      (dx >  JOY_THRESHOLD) ev = JOY_RIGHT;
      else if (dx < -JOY_THRESHOLD) ev = JOY_LEFT;
    } else {
      if      (dy >  JOY_THRESHOLD) ev = JOY_DOWN;
      else if (dy < -JOY_THRESHOLD) ev = JOY_UP;
    }

    TickType_t now = xTaskGetTickCount();
    if (ev != JOY_NONE) {
      if (!joyMoved || (now - lastRepeat > pdMS_TO_TICKS(300))) {
        xQueueSend(xJoyQueue, &ev, 0);
        joyMoved = true; lastRepeat = now;
      }
    } else {
      joyMoved = false;
    }

    if (btnNow == LOW && lastBtn == HIGH) {
      JoyEvent_t press = JOY_PRESS;
      xQueueSend(xJoyQueue, &press, 0);
      vTaskDelay(pdMS_TO_TICKS(50));
    }
    lastBtn = btnNow;
    vTaskDelay(pdMS_TO_TICKS(20));
  }
}

