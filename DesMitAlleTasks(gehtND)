}

// =====================================================
// TASK: SNAKE
// =====================================================
void vTaskSnake(void* pvParameters) {
  snakeReset();

  for (int i = 0; i < 3; i++) {
    if (xSemaphoreTake(xLedMutex, portMAX_DELAY) == pdTRUE) {
      clearLeds(); FastLED.show(); xSemaphoreGive(xLedMutex);
    }
    vTaskDelay(pdMS_TO_TICKS(200));
    if (xSemaphoreTake(xLedMutex, portMAX_DELAY) == pdTRUE) {
      for (int j = 0; j < snakeLength; j++)
        setPixelXY(snakeBody[j].x, snakeBody[j].y, CRGB::Blue);
      setPixelXY(snakeFood.x, snakeFood.y, CRGB::Red);
      FastLED.show(); xSemaphoreGive(xLedMutex);
    }
    vTaskDelay(pdMS_TO_TICKS(200));
  }

  TickType_t lastMove = xTaskGetTickCount();

  for (;;) {
    JoyEvent_t ev;
    if (xQueueReceive(xJoyQueue, &ev, 0) == pdTRUE && ev == JOY_PRESS) {
      gMenuState = MENU_MAIN; hTaskDisplay = NULL;
      vTaskDelete(NULL); return;
    }

    snakeReadJoystick();

    if (xTaskGetTickCount() - lastMove >= pdMS_TO_TICKS(snakeSpeed)) {
      lastMove = xTaskGetTickCount();

      int newX = snakeBody[0].x + snakeDirX;
      int newY = snakeBody[0].y + snakeDirY;

      if (snakeCheckCollision(newX, newY)) {
        for (int i = 0; i < 3; i++) {
          if (xSemaphoreTake(xLedMutex, portMAX_DELAY) == pdTRUE) {
            for (int j = 0; j < snakeLength; j++)
              setPixelXY(snakeBody[j].x, snakeBody[j].y, CRGB::Red);
            FastLED.show(); xSemaphoreGive(xLedMutex);
          }
          vTaskDelay(pdMS_TO_TICKS(150));
          if (xSemaphoreTake(xLedMutex, portMAX_DELAY) == pdTRUE) {
            clearLeds(); FastLED.show(); xSemaphoreGive(xLedMutex);
          }
          vTaskDelay(pdMS_TO_TICKS(150));
        }
        snakeReset(); lastMove = xTaskGetTickCount(); continue;
      }

      for (int i = snakeLength; i > 0; i--) snakeBody[i] = snakeBody[i - 1];
      snakeBody[0]  = {newX, newY};
      snakeLastDirX = snakeDirX;
      snakeLastDirY = snakeDirY;

      if (newX == snakeFood.x && newY == snakeFood.y) {
        if (snakeLength < MAX_SNAKE_LENGTH) {
          snakeLength++;
          snakeSpeed = max(SNAKE_MIN_SPEED, SNAKE_BASE_SPEED - (snakeLength * 3));
          if (xSemaphoreTake(xLedMutex, portMAX_DELAY) == pdTRUE) {
            for (int f = 0; f < 5; f++) {
              setPixelXY(snakeFood.x, snakeFood.y, CHSV(random(0, 255), 255, 255));
              FastLED.show();
              xSemaphoreGive(xLedMutex);
              vTaskDelay(pdMS_TO_TICKS(30));
              xSemaphoreTake(xLedMutex, portMAX_DELAY);
            }
            xSemaphoreGive(xLedMutex);
          }
        }
        snakeSpawnFood();
      }

      if (xSemaphoreTake(xLedMutex, portMAX_DELAY) == pdTRUE) {
        snakeDraw(); snakeHue++;
        FastLED.show(); xSemaphoreGive(xLedMutex);
      }
    }
    vTaskDelay(pdMS_TO_TICKS(10));
  }
}

// =====================================================
// HAUPT-MENÜ
// =====================================================
#define MENU_ITEMS 3
static const uint8_t (*MENU_ICONS[MENU_ITEMS])[8] = { ICON_WEATHER, ICON_CLOCK, ICON_SNAKE };
static const CRGB MENU_COLORS[MENU_ITEMS] = {
  CRGB(0, 160, 255), CRGB(255, 200, 0), CRGB(0, 220, 60)
};
static const MenuState_t MENU_TARGETS[MENU_ITEMS] = { MENU_WEATHER, MENU_CLOCK, MENU_SNAKE };

void renderMainMenu(int selected) {
  clearLeds();
  for (int i = 0; i < MENU_ITEMS; i++) {
    int  xPos   = 4 + i * 9;
    bool active = (i == selected);
    CRGB col    = active ? MENU_COLORS[i] : MENU_COLORS[i].scale8(55);
    for (int row = 0; row < 8; row++)
      for (int c = 0; c < 8; c++)
        if (MENU_ICONS[i][row][c]) setPixelXY(xPos + c, row, col);
    if (active) {
      setPixelXY(xPos + 3,  9, col); setPixelXY(xPos + 4,  9, col);
      setPixelXY(xPos + 3, 10, col); setPixelXY(xPos + 4, 10, col);
    }
  }
}

void vTaskMainMenu(void* pvParameters) {
  int selected = 0;
  for (;;) {
    if (gMenuState != MENU_MAIN) { vTaskDelay(pdMS_TO_TICKS(100)); continue; }

    JoyEvent_t ev;
    if (xQueueReceive(xJoyQueue, &ev, pdMS_TO_TICKS(50)) == pdTRUE) {
      if (ev == JOY_LEFT)  selected = (selected - 1 + MENU_ITEMS) % MENU_ITEMS;
      if (ev == JOY_RIGHT) selected = (selected + 1) % MENU_ITEMS;
      if (ev == JOY_PRESS) {
        gMenuState = MENU_TARGETS[selected];
        switch (gMenuState) {
          case MENU_WEATHER:
            gLabelScrollX  = MATRIX_WIDTH;
            gParticlesInit = false;
            xTaskCreatePinnedToCore(vTaskWeatherFetch,   "WFetch",  8192, NULL, 1, &hTaskWeather, 0);
            xTaskCreatePinnedToCore(vTaskWeatherScroll,  "WScroll", 2048, NULL, 2, &hTaskScroll,  0);
            xTaskCreatePinnedToCore(vTaskWeatherDisplay, "WDisp",   4096, NULL, 3, &hTaskDisplay, 1);
            break;
          case MENU_CLOCK:
            xTaskCreatePinnedToCore(vTaskClockDisplay, "Clock", 3072, NULL, 3, &hTaskDisplay, 1);
            break;
          case MENU_SNAKE:
            xTaskCreatePinnedToCore(vTaskSnake, "Snake", 4096, NULL, 3, &hTaskDisplay, 1);
            break;
          default: break;
        }
      }
    }

    if (xSemaphoreTake(xLedMutex, pdMS_TO_TICKS(30)) == pdTRUE) {
      renderMainMenu(selected);
      FastLED.show();
      xSemaphoreGive(xLedMutex);
    }
  }
}

// =====================================================
// SETUP
// =====================================================
void setup() {
  Serial.begin(115200);
  Serial.println("[Boot] Start...");

  FastLED.addLeds<CHIPSET, LED_PIN_1, COLOR_ORDER>(leds1, NUM_LEDS);
  FastLED.addLeds<CHIPSET, LED_PIN_2, COLOR_ORDER>(leds2, NUM_LEDS);
  FastLED.setBrightness(BRIGHTNESS);
  FastLED.clear();
  FastLED.show();
  Serial.println("[Boot] FastLED OK");

  xWeatherMutex = xSemaphoreCreateMutex();
  xLedMutex     = xSemaphoreCreateMutex();
  xJoyQueue     = xQueueCreate(8, sizeof(JoyEvent_t));
  Serial.println("[Boot] FreeRTOS Objekte OK");

  // FIX 7: WiFi im Hintergrund – blockiert den Start nicht mehr
  // Wetterdaten werden erst beim Öffnen des Wetter-Menüs geholt
  Serial.println("[Boot] WiFi wird im Hintergrund verbunden...");
  WiFi.begin(ssid, password);

  // Boot-Animation: Regenbogen-Sweep
  Serial.println("[Boot] Boot-Animation...");
  for (int i = 0; i < 256; i += 4) {
    for (int x = 0; x < MATRIX_WIDTH; x++)
      for (int y = 0; y < MATRIX_HEIGHT; y++)
        setPixelXY(x, y, CHSV(i + x * 8, 255, 255));
    FastLED.show();
    delay(10);
  }
  FastLED.clear();
  FastLED.show();
  delay(300);
  Serial.println("[Boot] Animation fertig");

  xTaskCreatePinnedToCore(vTaskInput,    "Input", 2048, NULL, 4, NULL,       0);
  xTaskCreatePinnedToCore(vTaskMainMenu, "Menu",  4096, NULL, 3, &hTaskMenu, 0);
  Serial.println("[Boot] Tasks gestartet – Menü läuft");
}

