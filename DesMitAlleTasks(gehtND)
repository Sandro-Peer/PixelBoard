    fetchWeather();
    vTaskDelay(pdMS_TO_TICKS(600000UL));
  }
}

// =====================================================
// TASK: WEATHER SCROLL
// =====================================================
void vTaskWeatherScroll(void* pvParameters) {
  for (;;) {
    vTaskDelay(pdMS_TO_TICKS(75));
    if (gMenuState != MENU_WEATHER) continue;

    int labelLen = 0;
    if (xSemaphoreTake(xWeatherMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
      labelLen = gWeather.label.length();
      xSemaphoreGive(xWeatherMutex);
    }
    if (labelLen == 0) continue;

    gLabelScrollX--;
    if (gLabelScrollX < -(labelLen * 4))
      gLabelScrollX = MATRIX_WIDTH;
  }
}

// =====================================================
// TASK: WEATHER DISPLAY
// =====================================================
void vTaskWeatherDisplay(void* pvParameters) {
  for (;;) {
    JoyEvent_t ev;
    if (xQueueReceive(xJoyQueue, &ev, 0) == pdTRUE && ev == JOY_PRESS) {
      if (hTaskWeather) { vTaskDelete(hTaskWeather); hTaskWeather = NULL; }
      if (hTaskScroll)  { vTaskDelete(hTaskScroll);  hTaskScroll  = NULL; }
      gMenuState   = MENU_MAIN;
      hTaskDisplay = NULL;
      vTaskDelete(NULL);
      return;
    }

    WeatherData wd;
    bool needInit = false;
    if (xSemaphoreTake(xWeatherMutex, pdMS_TO_TICKS(50)) == pdTRUE) {
      wd = gWeather;
      if (!gParticlesInit) { needInit = true; gParticlesInit = true; }
      xSemaphoreGive(xWeatherMutex);
    }
    if (needInit) initParticles();

    if (xSemaphoreTake(xLedMutex, portMAX_DELAY) == pdTRUE) {
      drawBackground(wd.condition);
      drawTemperature(wd.temp);
      drawWeatherLabel(wd.label, gLabelScrollX);
      FastLED.show();
      xSemaphoreGive(xLedMutex);
    }
    vTaskDelay(pdMS_TO_TICKS(20));
  }
}

// =====================================================
// TASK: CLOCK DISPLAY
// =====================================================
void vTaskClockDisplay(void* pvParameters) {
  for (;;) {
