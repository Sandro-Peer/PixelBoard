    }
  } else if (condition == 800) {
    static TickType_t last = 0;
    if (xTaskGetTickCount() - last > pdMS_TO_TICKS(100)) {
      last = xTaskGetTickCount();
      for (int i = 0; i < 20; i++) {
        particles[i].y += particles[i].speed;
        if (particles[i].y >= MATRIX_HEIGHT) { particles[i].y = 0; particles[i].x = random(0, MATRIX_WIDTH); }
        setPixelXY((int)particles[i].x, (int)particles[i].y, CHSV(35, 220, 130));
      }
    }
  } else if (condition > 800) {
    static TickType_t last = 0; static int cx = 0;
    if (xTaskGetTickCount() - last > pdMS_TO_TICKS(180)) { last = xTaskGetTickCount(); cx = (cx + 1) % MATRIX_WIDTH; }
    int pts[][2] = {{0,0},{1,0},{2,0},{3,0},{-1,0},{0,-1},{1,-1},{2,-1},{0,1},{1,1},{2,1}};
    for (auto& p : pts) {
      setPixelXY((cx + p[0] + MATRIX_WIDTH) % MATRIX_WIDTH, constrain(4  + p[1], 0, 7),  CRGB(55,55,55));
      setPixelXY((cx + p[0] + MATRIX_WIDTH) % MATRIX_WIDTH, constrain(11 + p[1], 8, 15), CRGB(55,55,55));
    }
  } else if (condition >= 200 && condition < 300) {
    static TickType_t lastBolt = 0, boltStart = 0;
    static bool boltOn = false; static int bx = 16;
    if (!boltOn && xTaskGetTickCount() - lastBolt > pdMS_TO_TICKS(random(800, 2500))) {
      boltOn = true; bx = random(3, MATRIX_WIDTH - 3); boltStart = lastBolt = xTaskGetTickCount();
    }
    if (boltOn) {
      int x = bx;
      for (int y = 0; y < MATRIX_HEIGHT; y++) {
        setPixelXY(x, y, CRGB(220, 220, 80));
        if (y % 3 == 1) x += random(-1, 2);
        x = constrain(x, 0, MATRIX_WIDTH - 1);
      }
      if (xTaskGetTickCount() - boltStart > pdMS_TO_TICKS(80)) boltOn = false;
    }
  } else if (condition >= 700 && condition < 800) {
    static uint32_t t = 0; t += 2;
    for (int x = 0; x < MATRIX_WIDTH; x++)
      for (int y = 0; y < MATRIX_HEIGHT; y++) {
        uint8_t n = inoise8(x * 30, y * 30, t);
        uint8_t b = map(n, 0, 255, 8, 45);
        setPixelXY(x, y, CRGB(b, b, b + 10));
      }
  }
}

void drawTemperature(float temp) {
  uint8_t chars[6]; int len = 0;
  int t = (int)round(temp);
  if (t < 0) { chars[len++] = 12; t = -t; }
  if (t >= 10) chars[len++] = t / 10;
  chars[len++] = t % 10; chars[len++] = 10; chars[len++] = 11;
  CRGB col;
  if      (temp <= 0)  col = CRGB(80,  160, 255);
  else if (temp <= 10) col = CRGB(0,   200, 255);
  else if (temp <= 20) col = CRGB(0,   220,  80);
  else if (temp <= 30) col = CRGB(255, 200,   0);
  else                 col = CRGB(255,  60,   0);
  int totalW = len * 6 - 1;
  int startX = (MATRIX_WIDTH - totalW) / 2;
  int startY = (MATRIX_HEIGHT - 7) / 2;
  for (int i = 0; i < len; i++) drawLargeChar(startX + i * 6, startY, chars[i], col);
}

void drawWeatherLabel(const String& label, int scrollX) {
  String lbl = label; lbl.toLowerCase();
  for (int i = 0; i < (int)lbl.length(); i++) {
    char c = lbl[i];
