// =====================================================
// XY-MAPPING
// =====================================================
uint16_t XY_matrix(uint8_t x, uint8_t y) {
  if (x >= WIDTH || y >= HEIGHT) return 0;
  uint8_t realX = WIDTH - 1 - x;
  if (realX % 2 == 0) return (realX * HEIGHT) + y;
  else                return (realX * HEIGHT) + (HEIGHT - 1 - y);
}

void setPixelXY(uint8_t x, uint8_t y, const CRGB& color) {
  if (x >= MATRIX_WIDTH) return;
  if (y < HEIGHT) {
    leds1[XY_matrix(x, y)] = color;
  } else if (y < MATRIX_HEIGHT) {
    uint8_t localY  = y - HEIGHT;
    uint8_t mappedX = WIDTH  - 1 - x;
    uint8_t mappedY = HEIGHT - 1 - localY;
    leds2[XY_matrix(mappedX, mappedY)] = color;
  }
}

void clearLeds() {
  memset(leds1, 0, sizeof(leds1));
  memset(leds2, 0, sizeof(leds2));
}

